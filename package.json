{
  "name": "command-code-proxy",
  "version": "1.0.0",
  "description": "Proxy that lets Claude Code use Command Code's free API — access 25+ models (GPT, Gemini, DeepSeek, Qwen, etc.) through Claude Code's interface",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "setup": "node setup.js",
    "restore": "node setup.js --restore",
    "status": "node setup.js --status"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "keywords": [
    "claude-code",
    "command-code",
    "proxy",
    "anthropic",
    "openai",
    "deepseek",
    "gemini",
    "free-api",
    "ai-models"
  ],
  "author": "SomuG25",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SomuG25/command-code-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/SomuG25/command-code-proxy/issues"
  },
  "homepage": "https://github.com/SomuG25/command-code-proxy#readme",
  "devDependencies": {
    "dotenv": "^17.4.2",
    "jest": "^30.4.2"
  }
}
