# ─── command-code-proxy configuration ────────────────────────────────────────
# Copy this file to .env and edit to your needs.
# All settings are optional — the proxy works out of the box without this file.

# Port the proxy listens on (default: 4141)
# CC_PROXY_PORT=4141

# Default model when none is specified (default: claude-sonnet-4-6)
# Supports short aliases: deepseek, gemini, gpt, qwen, kimi, sonnet, haiku, opus
# CC_PROXY_DEFAULT_MODEL=deepseek/deepseek-v4-pro

# ─── Logging ──────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error | silent  (default: info)
# LOG_LEVEL=info

# Write logs to a file in addition to stdout (optional)
# LOG_FILE=proxy.log
